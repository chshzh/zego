config ZEGO_WIFI_BLE_PROV
	bool "Zego Wi-Fi BLE provisioning module"
	depends on ZEGO_NETWORK && ZBUS && WIFI_CREDENTIALS
	select BT
	select BT_PERIPHERAL
	select BT_SMP
	select BT_WIFI_PROV
	select WIFI_PROV_CORE
	select NANOPB
	select REBOOT
	help
	  BLE-based Wi-Fi credential provisioning using the nRF Wi-Fi Provisioner
	  app (Android / iOS).

	  Provides:
	    - WIFI_CHAN (struct wifi_msg): zbus channel for Wi-Fi connect/disconnect.
	      The app's net_event_app.c must declare and publish to this channel.
	    - SYS_INIT APPLICATION priority 95: BT init + Wi-Fi provisioning service.
	    - Automatic credential-based reconnect after provisioning.
	    - Rotating retry across all stored networks on disconnect.
	    - DHCP-bind watchdog that reboots to recover from a known
	      wifi_prov_core disconnect+connect race (see
	      CONFIG_ZEGO_WIFI_BLE_PROV_DHCP_WATCHDOG_SEC).

	  Enable in prj.conf:  CONFIG_ZEGO_WIFI_BLE_PROV=y

if ZEGO_WIFI_BLE_PROV

config ZEGO_WIFI_BLE_PROV_ADV_DAEMON_STACK_SIZE
	int "BLE advertising daemon work queue stack size (bytes)"
	default 4096
	help
	  Stack size for the ble_adv_daemon_wq work queue thread that drives
	  BLE advertising parameter and data updates during Wi-Fi provisioning.

config ZEGO_WIFI_BLE_PROV_DHCP_WATCHDOG_SEC
	int "Reboot if DHCP doesn't bind within N seconds of a connect (0 = disabled)"
	default 25
	range 0 300
	help
	  Nordic's wifi_prov_core library issues NET_REQUEST_WIFI_DISCONNECT
	  immediately followed by NET_REQUEST_WIFI_CONNECT when new Wi-Fi
	  credentials are provisioned over BLE, with no wait for the
	  disconnect to actually complete.  On some nRF70 + host combinations
	  this wedges wpa_supplicant's control interface: the interface
	  reports STA associated (wifi status / CONNECT_RESULT) but the
	  control-socket transport itself is jammed, so DHCP never binds and
	  no further Wi-Fi command (disconnect/connect/status) can recover it
	  - only a reboot clears the wedge.

	  When this watchdog fires (DHCP still unbound N seconds after a
	  Wi-Fi connect observed by this module), the device performs a warm
	  reboot to recover.  Set to 0 to disable.

module = ZEGO_WIFI_BLE_PROV
module-str = zego_wifi_ble_prov
source "${ZEPHYR_BASE}/subsys/logging/Kconfig.template.log_config"

endif # ZEGO_WIFI_BLE_PROV

rsource "Kconfig.defaults"
