menu "Nordic Wi-Fi App Template"

config APP_WIFI_SSID
	string "Wi-Fi SoftAP SSID"
	default "nRF7x_AP"
	help
	  SSID used when operating in SoftAP or P2P_GO mode.

config APP_WIFI_PASSWORD
	string "Wi-Fi SoftAP Password"
	default "12345678"
	help
	  Password for SoftAP (min 8 characters for WPA2).

# mode_selector and network Kconfig provided by zego/wifi and zego/network
# (EXTRA_ZEPHYR_MODULES) — no rsource needed here.
# button, led, and ux Kconfig registered via EXTRA_ZEPHYR_MODULES
# (zego/button, zego/led, zego/ux).

endmenu

source "Kconfig.zephyr"
