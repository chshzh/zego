config ZEGO_LED
	bool "Zego LED module"
	select DK_LIBRARY
	select ZBUS
	select SMF
	help
	  Enable LED control using an SMF state machine.  Subscribes to
	  LED_CMD_CHAN (zbus) and drives DK LEDs.  Publishes LED_STATE_CHAN after
	  every hardware state change.  The module auto-initializes via SYS_INIT.

	  Publish to LED_CMD_CHAN with struct led_msg to command an LED.
	  See zego/led/docs/led-spec.md for the integration guide.

if ZEGO_LED

config ZEGO_LED_NUM_LEDS
	int "Number of LEDs to control"
	default 4
	range 1 4
	help
	  Number of DK LEDs to manage (0-based indices 0 to N-1).
	  Override this in boards/<board>.conf:
	    nrf7002dk_nrf5340_cpuapp       → 2
	    nrf54lm20dk_nrf54lm20a_cpuapp  → 4

config ZEGO_LED_INIT_PRIORITY
	int "Initialization priority (SYS_INIT APPLICATION level)"
	default 91
	help
	  SYS_INIT priority for the LED module.  Must be greater than the DK
	  library's own init priority.  Set higher than ZEGO_BUTTON_INIT_PRIORITY
	  if both modules are enabled.

config ZEGO_LED_BLINK_PERIOD_MS
	int "Default blink half-period in milliseconds"
	default 250
	range 50 10000
	help
	  Time the LED stays on (and off) for each blink half-cycle when
	  LED_COMMAND_BLINK is sent with period_ms = 0.  Full cycle = 2x this value.

config ZEGO_LED_BREATHE_PERIOD_MS
	int "Breathe ramp duration per direction in milliseconds"
	default 3000
	range 200 30000
	help
	  Time for one ramp direction (fade-up or fade-down) when
	  LED_COMMAND_BREATHE is sent with period_ms = 0.
	  Full cycle = 2 × this value (default: 3 s up + 3 s down = 6 s total).
	  Number of PWM steps = this value / CONFIG_ZEGO_LED_BREATHE_PWM_PERIOD_MS.

config ZEGO_LED_BREATHE_PWM_PERIOD_MS
	int "Breathe software-PWM frame duration in milliseconds"
	default 20
	range 5 100
	help
	  Duration of one software-PWM cycle used by the breathe effect.
	  The duty cycle steps linearly across CONFIG_ZEGO_LED_BREATHE_PERIOD_MS /
	  this value steps per ramp direction.  Lower values give finer brightness
	  resolution; higher values reduce CPU wake-ups but produce a coarser step.
	  Default 20 ms (50 Hz) gives 150 steps per 3 s ramp.

config ZEGO_LED_MARQUEE_PERIOD_MS
	int "Default marquee step period in milliseconds"
	default 500
	range 50 5000
	help
	  Time each LED stays lit during the marquee sweep when
	  LED_COMMAND_MARQUEE is sent with period_ms = 0.

module = ZEGO_LED
module-str = zego_led
source "subsys/logging/Kconfig.template.log_config"

endif # ZEGO_LED
