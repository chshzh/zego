config ZEGO_BUTTON
	bool "Zego button module"
	select DK_LIBRARY
	select ZBUS
	select SMF
	help
	  Enable debounced button monitoring using an SMF state machine.
	  Monitors DK buttons and publishes BUTTON_PRESSED and BUTTON_RELEASED
	  events on BUTTON_CHAN (zbus).  The module auto-initializes via SYS_INIT.

	  Include <zego/button.h> and use ZBUS_CHAN_ADD_OBS(BUTTON_CHAN, ...) to
	  subscribe.  See zego/button/docs/button-spec.md for the integration guide.

if ZEGO_BUTTON

config ZEGO_BUTTON_NUM_BUTTONS
	int "Number of buttons to monitor"
	default 4
	range 1 4
	help
	  Number of DK buttons to monitor (0-based indices 0 to N-1).
	  Override this in boards/<board>.conf:
	    nrf7002dk_nrf5340_cpuapp      → 2  (Button 1, Button 2)
	    nrf54lm20dk_nrf54lm20a_cpuapp → 4  (BUTTON0–BUTTON3)
	  Note: when nrf54lm20dk is used with -DSHIELD=nrf7002eb2 the shield
	  occupies BUTTON3; the application should override to 3 in its own
	  boards/<board>.conf.

config ZEGO_BUTTON_LONG_PRESS_MS
	int "Long-press threshold (ms)"
	default 3000
	help
	  Press duration (ms) at which a BUTTON_LONG_PRESS event is published.
	  The event fires while the button is still held.

config ZEGO_BUTTON_DOUBLE_CLICK_WINDOW_MS
	int "Double-click detection window (ms)"
	default 300
	help
	  Maximum interval between two presses to detect a BUTTON_DOUBLE_CLICK.
	  After a press+release the module waits this long for a 2nd press.
	  If none arrives, BUTTON_SINGLE_CLICK is published instead.

config ZEGO_BUTTON_INIT_PRIORITY
	int "Initialization priority (SYS_INIT APPLICATION level)"
	default 90
	help
	  SYS_INIT priority for the button module.  Must be greater than the DK
	  library's own init priority.

module = ZEGO_BUTTON
module-str = zego_button
source "subsys/logging/Kconfig.template.log_config"

endif # ZEGO_BUTTON
